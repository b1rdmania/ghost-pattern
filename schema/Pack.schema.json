{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pack",
  "type": "object",
  "required": ["id", "title", "description", "sceneTag", "studyIds"],
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "description": {
      "type": "string",
      "description": "One or two sentences on editorial intent."
    },
    "sceneTag": { "type": "string" },
    "studyIds": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    }
  }
}
